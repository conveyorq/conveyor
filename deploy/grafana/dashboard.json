{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping conveyord /metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["conveyor"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "queue",
        "label": "Queue",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(conveyor_pending, queue)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "",
  "title": "Conveyor",
  "uid": "conveyor-overview",
  "panels": [
    {
      "title": "Throughput",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Per-second rate of task lifecycle events across the cluster.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(conveyor_enqueued_total[$__rate_interval]))", "legendFormat": "enqueued" },
        { "refId": "B", "expr": "sum(rate(conveyor_dispatched_total[$__rate_interval]))", "legendFormat": "dispatched" },
        { "refId": "C", "expr": "sum(rate(conveyor_completed_total[$__rate_interval]))", "legendFormat": "completed" },
        { "refId": "D", "expr": "sum(rate(conveyor_failed_total[$__rate_interval]))", "legendFormat": "failed" },
        { "refId": "E", "expr": "sum(rate(conveyor_retried_total[$__rate_interval]))", "legendFormat": "retried" },
        { "refId": "F", "expr": "sum(rate(conveyor_released_total[$__rate_interval]))", "legendFormat": "released (drains)" }
      ]
    },
    {
      "title": "Active executions",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Executions currently in flight, summed across nodes.",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(conveyor_active)", "legendFormat": "active" }
      ]
    },
    {
      "title": "Failure rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Share of finished executions that failed.",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 } ] }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(conveyor_failed_total[$__rate_interval])) / clamp_min(sum(rate(conveyor_completed_total[$__rate_interval])) + sum(rate(conveyor_failed_total[$__rate_interval])), 1)", "legendFormat": "failure rate" }
      ]
    },
    {
      "title": "Pending depth by queue",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Tasks due and waiting to dispatch, per queue.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (queue) (conveyor_pending{queue=~\"$queue\"})", "legendFormat": "{{queue}}" }
      ]
    },
    {
      "title": "Cluster members",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "conveyord nodes currently exposing metrics.",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "count(count by (instance) (conveyor_active))", "legendFormat": "nodes" }
      ]
    },
    {
      "title": "Actor restarts",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "GoAkt actor restart rate (WithMetrics). A sustained rise signals relocation churn or failing actors.",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(actor_restart_count_total[$__rate_interval]))", "legendFormat": "restarts" }
      ]
    }
  ]
}
