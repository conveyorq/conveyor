bin/
coverage.out
*.test
.idea/
.vscode/
.cache/
.gocache/
.gomodcache/
# Proto staging dir at the repo root (make proto). Anchored so it does NOT
# match the committed generated TS client at web/dashboard/src/gen.
/gen/
.claude/

# go test compiled binaries left by `go test -c` / `-cpuprofile`
*.test
*.prof
.local/


*coverage.*
vendor
gen.env
# Dashboard frontend: ignore deps and the built bundle. dist/ is built in CI
# and in the Docker image (Node stage), not committed. The .gitkeep keeps the
# directory present so the Go //go:embed of dist/ still compiles on a fresh
# checkout (the bundle is empty until built; see web/dashboard/README or
# `make dashboard`).
web/dashboard/node_modules/
web/dashboard/dist/*
!web/dashboard/dist/.gitkeep

# Node dependencies and build output anywhere (TS SDK, examples). Unanchored so
# it matches node_modules/ in every package; package-lock.json stays tracked
# for reproducible installs.
node_modules/
sdks/typescript/dist/
examples/typescript/**/dist/

# Python SDK and examples: ignore virtualenvs, caches, and build output. The
# generated stubs under sdks/python/src/conveyorq/gen are committed (regenerate
# with `make sdk-py-gen`); everything else here is local.
.venv*/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
sdks/python/build/
sdks/python/dist/
